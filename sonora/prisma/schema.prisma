// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  username String @unique
  displayName    String?
  slug           String   @unique

  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  chartProfile ChartProfile[]
}

enum ChartStatus {
  SETUP
  SYNCING
  ACTIVE
  ERROR
}

model ChartProfile {
  id String @id @default(cuid())
  userId String

  chartName String 
  slug String @unique

  startDate DateTime
  weekStartDay Int
  
  status ChartStatus @default(SETUP) 

  isDefault Boolean @default(false)
  isPublic Boolean @default(true)

  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  settings ChartSetting[]
  certifications CertificationRule[]

  @@unique([userId, slug])
}

enum ChartType {
  TRACK
  ALBUM
  ARTIST
}

model ChartSetting {
  id String @id @default(cuid())

  chartId String
  chartType ChartType

  maxPositions Int
  maxPoints Int @default(100)
  pointDecay Int @default(1)
  minPoints Int @default(1)

  playsWeight Float @default(1)
  pointsWeight Float @default(1)

  minPlaysToChart Int @default(1)

  profile ChartProfile @relation(fields: [chartId], references: [id])

  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  @@unique([chartId, chartType])
}

model CertificationRule {
  id String @id @default(cuid())

  chartId String
  chartType ChartType

  goldCertification Float
  platinumCertification Float
  diamondCertification Float

  profile ChartProfile @relation(fields: [chartId], references: [id])

  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt

  @@unique([chartId, chartType])

}